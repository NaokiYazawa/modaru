{
  "name": "modaru",
  "version": "0.1.0",
  "description": "Type-safe imperative modals for React — open a modal, await its typed outcome. Headless: bring your own dialog primitives.",
  "keywords": [
    "react",
    "modal",
    "dialog",
    "imperative",
    "promise",
    "await",
    "headless",
    "typescript",
    "confirm",
    "outcome"
  ],
  "license": "MIT",
  "author": "Naoki Yazawa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NaokiYazawa/modaru.git"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": ["./dist/testing.d.ts"]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "default": "./dist/testing.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "check": "biome check src",
    "prepublishOnly": "bun run check-types && bun run test && bun run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "homepage": "https://github.com/NaokiYazawa/modaru#readme",
  "bugs": {
    "url": "https://github.com/NaokiYazawa/modaru/issues"
  }
}
